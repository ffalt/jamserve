{
  "name": "jamserve",
  "version": "0.6.14",
  "author": "ffalt",
  "license": "MIT",
  "description": "jamserve streaming audio server",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/ffalt/jamserve.git"
  },
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "start": "node dist/index.js",
    "develop": "tsc-watch --onSuccess \"node ./dist/index.js\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "tsc",
    "build:prod": "npm run clean && npm run build",
    "build:deploy": "npm run build:prod && node --loader ts-node/esm deploy.ts",
    "check": "qlty check --all",
    "clean": "rimraf dist",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest",
    "test:watch": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --watch",
    "coverage": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --coverage",
    "release": "npx commit-and-tag-version",
    "changelog:start": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 1",
    "releaselog": "node .github/scripts/extract-release.mjs"
  },
  "overrides": {
    "axios": "1.16.0",
    "brace-expansion": "5.0.6",
